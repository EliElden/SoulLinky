# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Настройки HTTP прокси (если нужно)
# Формат: http://LOGIN:PASSWORD@IP:PORT
# Можно оставить пустым, если запускаешь с VPN
PROXY_URL=http://username:password@127.0.0.1:8000

# Числовые ID администраторов бота (можно указать несколько через запятую, без пробелов).
# Админы имеют доступ к скрытым командам (например, к рассылке /broadcast).
# Чтобы узнать свой ID, запусти бота и отправь команду /id
ADMIN_IDS=123456789,987654321
